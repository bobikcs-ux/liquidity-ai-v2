{
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/market-snapshot",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/sync-all",
      "schedule": "*/30 * * * *"
    }
  ]
}
